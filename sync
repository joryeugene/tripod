#!/usr/bin/env bash
set -e

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"
INSTALLED_FILE="$HOME/.claude/plugins/installed_plugins.json"
PLUGIN_KEY="claude-stack@claude-stack"

# Find the install path from the plugin registry
if [[ ! -f "$INSTALLED_FILE" ]]; then
  echo "error: no installed plugins found"
  echo "  run: claude plugin marketplace add joryeugene/claude-stack"
  echo "       claude plugin install claude-stack"
  exit 1
fi

install_path=$(python3 -c "
import json, sys
data = json.load(open('$INSTALLED_FILE'))
entries = data.get('plugins', {}).get('$PLUGIN_KEY', [])
if not entries:
    sys.exit(1)
print(entries[0]['installPath'])
" 2>/dev/null)

if [[ -z "$install_path" || ! -d "$install_path" ]]; then
  echo "error: claude-stack plugin not installed"
  echo "  run: claude plugin install claude-stack"
  exit 1
fi

# Sync repo contents to the plugin cache
# Only sync the directories and files that the plugin uses
synced=0
for item in skills hooks CLAUDE.md README.md setup verify statusline.sh scripts mcp-presets settings.json.example env.sh.example; do
  src="$REPO_DIR/$item"
  dst="$install_path/$item"
  if [[ -e "$src" ]]; then
    if [[ -d "$src" ]]; then
      rsync -a --delete "$src/" "$dst/"
    else
      cp "$src" "$dst"
    fi
    synced=$((synced + 1))
  fi
done

# Count what was synced
skill_count=$(ls "$install_path/skills/" 2>/dev/null | wc -l | tr -d ' ')
hook_count=$(ls "$install_path/hooks/"*.py 2>/dev/null | wc -l | tr -d ' ')

echo "synced $synced items to plugin cache"
echo "  skills: $skill_count"
echo "  hooks:  $hook_count"
echo "  path:   $install_path"
echo ""
echo "Start a new session to pick up changes."
