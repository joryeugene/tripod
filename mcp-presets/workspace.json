{
  "_description": "Google Docs, Drive, Calendar, Sheets",
  "mcpServers": {
    "workspace": {
      "command": "uvx",
      "args": [
        "workspace-mcp",
        "--tools", "docs", "drive", "calendar", "sheets",
        "--single-user",
        "--transport", "stdio"
      ],
      "env": {
        "GOOGLE_CLIENT_SECRET_PATH": "~/.config/workspace-mcp/client_secret.json"
      }
    }
  }
}
