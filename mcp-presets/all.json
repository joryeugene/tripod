{
  "_description": "everything: workspace + browser + shadcn-ui + asana",
  "mcpServers": {
    "workspace": {
      "command": "uvx",
      "args": [
        "workspace-mcp",
        "--tools", "docs", "drive", "calendar", "sheets",
        "--single-user",
        "--transport", "stdio"
      ],
      "env": {
        "GOOGLE_CLIENT_SECRET_PATH": "~/.config/workspace-mcp/client_secret.json"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest", "--autoConnect"]
    },
    "shadcn-ui": {
      "command": "npx",
      "args": ["-y", "shadcn-ui-mcp-server"]
    },
    "asana": {
      "command": "npx",
      "args": ["-y", "@roychri/mcp-server-asana"],
      "env": {
        "ASANA_ACCESS_TOKEN": ""
      }
    }
  }
}
